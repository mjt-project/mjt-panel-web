/**
 * Public data contracts shared by the legacy Minecraft panel and the newer
 * panel-first service UI. Keep legacy aliases exported while the UI migrates.
 */

export type ServerStatus = 'running' | 'stopped' | 'starting' | 'unknown';
export type ServerSoftware = 'velocity' | 'paper' | 'purpur' | 'minecraft';

export interface ServerProfile {
  name: string;
  type: ServerSoftware | string;
  workdir?: string;
  command?: string;
  port?: number;
  running: boolean;
  status?: ServerStatus;
  version?: string;
}

/** Legacy name used by existing feature pages. */
export type MinecraftProfile = ServerProfile;

export interface PanelStatus {
  version?: string;
  remote?: string;
  activeProfile?: string;
}

/** Legacy dashboard/system contract. */
export interface CoreStatus extends PanelStatus {
  uptime?: string;
  panelUrl?: string;
  apiVersion?: string;
}

export interface SystemStatus {
  java?: string;
  architecture?: string;
  memory?: string;
  os?: string;
  disk?: string;
  panelFrontend?: string;
  cloudflared?: string;
  [key: string]: unknown;
}

export interface FileEntry {
  name: string;
  path: string;
  /** Original Core Files API representation. */
  directory?: boolean;
  /** UI-friendly representation retained for existing feature pages. */
  type?: 'file' | 'directory';
  size?: number | string;
  modifiedAt?: string;
}

export interface BackupItem {
  id: string;
  name: string;
  createdAt?: string;
  size?: string;
  status?: string;
}

export interface PlayerItem {
  name: string;
  uuid?: string;
  online: boolean;
  ping?: number;
  joinedAt?: string;
  op?: boolean;
  whitelisted?: boolean;
}

export interface InstallRequest {
  software: 'velocity' | 'paper' | 'purpur';
  provider?: string;
  profile: string;
  version?: string;
  build?: string;
  port?: number;
  memory?: string;
  acceptEula?: boolean;
  force?: boolean;
}

export interface Capabilities {
  files: boolean;
  backups: boolean;
  players: boolean;
  network: boolean;
  system: boolean;
}
